# 依赖项
node_modules/
package-lock.json

# 构建产物
dist/
dist-server/
build/

# IDE 与 AI 工具
.agent/
.shared/
.vscode/
.idea/
*.swp
*.swo
*~

# 环境变量
.env
.env.local
.env.production
.env.backup

# 日志文件
logs/
*.log
npm-debug.log*

# 用户数据 (排除所有本地数据，仅保留目录结构)
data/*
!data/.gitkeep
# 为了安全，显式忽略数据库内部文件
*.db
*.db-journal
*.db-wal
*.db-shm

# 本地实例信息
data/instance.id
data/license.key

# 插件与离线包
# 允许提交插件源代码，但排除每个插件内部的依赖、构建产物和私有数据
plugins/*/node_modules/
plugins/*/dist/
plugins/*/build/
plugins/*/data/
plugins/*/logs/
plugins/*/*.log
plugins/*/*.zip
plugins/*/*.exe
plugins/*/*.bin

# 排除特定的本地缓存目录
dist-plugins/
Navlink-plugins/
tmp_packages/

# 操作系统相关
.DS_Store
Thumbs.db

# 临时文件与缓存
tmp/
temp/
*.tmp
data/cache/
data/transcode_cache/
data/transcode/
data/uploads/
