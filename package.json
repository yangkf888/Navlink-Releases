{
    "name": "navlink-next",
    "version": "2.1.11",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "dev:backend": "node server.js",
        "dev:all": "concurrently \"npm run dev\" \"npm run dev:backend\" --names \"frontend,backend\" --prefix-colors \"blue,green\"",
        "build": "vite build",
        "preview": "vite preview",
        "obfuscate:backend": "node scripts/obfuscate-backend.js",
        "build:all": "npm run build && npm run obfuscate:backend",
        "package-plugins": "node scripts/package-plugins.cjs",
        "test": "vitest",
        "test:run": "vitest run",
        "test:ui": "vitest --ui",
        "test:coverage": "vitest run --coverage",
        "migrate:make": "node scripts/make_migration.js",
        "migrate:latest": "node server/database/migrationRunner.js",
        "build:docker": "npm run build:all && docker build . -t ghcr.io/txwebroot/navlink-releases:latest && docker tag ghcr.io/txwebroot/navlink-releases:latest ghcr.io/txwebroot/navlink-releases:$(node -p \"require('./package.json').version\")"
    },
    "dependencies": {
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/modifiers": "^9.0.0",
        "@dnd-kit/sortable": "^10.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "@hello-pangea/dnd": "^18.0.1",
        "@iconify/react": "^6.0.2",
        "adm-zip": "^0.5.16",
        "axios": "^1.6.0",
        "bcrypt": "^6.0.0",
        "better-sqlite3": "^12.5.0",
        "body-parser": "^1.20.2",
        "clsx": "^2.1.1",
        "compression": "^1.8.1",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "csurf": "^1.11.0",
        "date-fns": "^4.1.0",
        "dotenv": "^17.2.3",
        "elliptic": "^6.6.1",
        "express": "^4.18.2",
        "express-mongo-sanitize": "^2.2.0",
        "express-rate-limit": "^8.2.1",
        "framer-motion": "^12.23.25",
        "helmet": "^8.1.0",
        "hpp": "^0.2.3",
        "http-proxy-middleware": "^2.0.6",
        "ioredis": "^5.8.2",
        "jsonwebtoken": "^9.0.3",
        "lucide-react": "^0.555.0",
        "multer": "^2.0.2",
        "node-cron": "^3.0.3",
        "node-fetch": "^3.3.2",
        "pinyin-pro": "^3.27.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-hot-toast": "^2.6.0",
        "react-router-dom": "^6.18.0",
        "redis": "^5.10.0",
        "sharp": "^0.34.5",
        "socket.io": "^4.7.2",
        "socket.io-client": "^4.7.2",
        "sqlite3": "^5.1.7",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.1",
        "swr": "^2.3.7",
        "tailwind-merge": "^3.4.0",
        "uuid": "^9.0.1",
        "winston": "^3.18.3",
        "winston-daily-rotate-file": "^5.0.0"
    },
    "devDependencies": {
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.0",
        "@types/react": "^18.2.37",
        "@types/react-dom": "^18.2.15",
        "@vitejs/plugin-react": "^4.2.0",
        "autoprefixer": "^10.4.16",
        "concurrently": "^8.2.2",
        "javascript-obfuscator": "^5.1.0",
        "jsdom": "^27.3.0",
        "postcss": "^8.4.31",
        "tailwindcss": "^3.3.5",
        "typescript": "^5.2.2",
        "vite": "^7.2.7",
        "vitest": "^4.0.15"
    }
}