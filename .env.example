# NavLink Environment Configuration
# Copy this file to .env and update the values

# Server Configuration
NODE_ENV=development
PORT=3001

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=24h

# Logging Configuration
LOG_LEVEL=info
LOG_DIR=./logs

# Database Configuration
DB_PATH=./data

# Security Configuration
# Rate Limiting (requests per 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
CORS_ORIGIN=http://localhost:5173,http://localhost:3001
CORS_CREDENTIALS=true

# Session Configuration
SESSION_SECRET=your-super-secret-session-key-change-this-in-production

# Plugin Configuration
PLUGINS_DIR=./plugins
PLUGIN_PORT_START=8000
PLUGIN_PORT_END=9000

# Admin Default Credentials (CHANGE IMMEDIATELY!)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123

# Encryption Key for sensitive data (VPS passwords, etc.)
ENCRYPTION_KEY=your-32-character-encryption-key-change-this

# Redis Configuration (Optional, for caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Email Configuration (Optional, for notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=7
BACKUP_PATH=./backups

# Feature Flags
ENABLE_REGISTRATION=false
ENABLE_MULTI_TENANT=true
ENABLE_METRICS=true
ENABLE_SWAGGER_DOCS=false

# Plugin Market Registry (应用商城注册表)
# 用户无需修改此地址，将自动使用官方应用商城
PLUGIN_REGISTRY_URL=https://raw.githubusercontent.com/txwebroot/NavLink/refs/heads/main/Navlink-plugins/plugin-registry.json

# GitHub Personal Access Token (如果应用商城仓库是私有的)
# 创建 token: GitHub Settings → Developer settings → Personal access tokens → Fine-grained tokens
# 权限: Repository access → Only select repositories → 选择 navlink-plugins 仓库
# Repository permissions: Contents (Read-only)
PLUGIN_REGISTRY_TOKEN=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
