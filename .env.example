# NavLink Environment Configuration (Production)
# ⚠️ SECURITY WARNING: Keep this file secure! It contains sensitive credentials.

# Server Configuration
NODE_ENV=production
PORT=3001

# Security Keys (EXTRACTED FROM DOCKER-COMPOSE)
# ⚠️ Do NOT change ENCRYPTION_KEY unless you want to invalidate all existing VPS/SSH passwords
ENCRYPTION_KEY=navlink-default-encryption-key-32
JWT_SECRET=navlink-default-jwt-secret-please-change-in-production-2024
SESSION_SECRET=navlink-default-session-secret-please-change-in-production-2024

#token过期时间
JWT_EXPIRES_IN=365d

# Admin Default Credentials
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123

# Redis Configuration
REDIS_ENABLED=true
REDIS_HOST=redis
REDIS_PORT=6379

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 2 * * *"
BACKUP_RETENTION_DAYS=7
BACKUP_PATH=./backups


# External Services Configuration
# 授权服务器地址 (注册验证、迁移验证等)，请自行根据协议开发（如有需要）
AUTH_SERVER_URL=https://auth.webxx.top

# 插件市场注册表地址
PLUGIN_REGISTRY_URL=https://auth.webxx.top/api/registry.json
#  GitHub 示例: PLUGIN_REGISTRY_URL=https://raw.githubusercontent.com/txwebroot/Navlink-plugins/main/registry.json
#  registryjson示例参考:docs/插件注册表示例.json

# 系统更新仓库配置 (GitHub)
UPDATE_OWNER=txwebroot  
UPDATE_REPO=Navlink-Releases


# 免激活模式 (设置为 true 则跳过授权验证，建议由用户按需修改)
SKIP_LICENSE=true
