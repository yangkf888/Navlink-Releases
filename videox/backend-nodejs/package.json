{
    "name": "videox-backend",
    "version": "1.0.2",
    "description": "VideoX - Standalone Video Aggregation Application",
    "main": "server.js",
    "scripts": {
        "start": "node server.js",
        "dev": "node server.js",
        "build": "javascript-obfuscator . --output ./dist-server --compact true --self-defending true --string-array true --string-array-encoding 'rc4' --string-array-threshold 0.75 --dead-code-injection true --dead-code-injection-threshold 0.4 --ignore-imports true --exclude \"node_modules/*,dist-server/*,data/*\""
    },
    "devDependencies": {
        "javascript-obfuscator": "^4.1.0"
    },
    "dependencies": {
        "axios": "^1.13.2",
        "better-sqlite3": "^11.5.0",
        "cors": "^2.8.5",
        "express": "^4.18.2",
        "fast-xml-parser": "^5.3.3",
        "fluent-ffmpeg": "^2.1.3",
        "https-proxy-agent": "^7.0.6",
        "multiparty": "^4.2.3",
        "node-fetch": "^2.7.0",
        "p-limit": "^7.2.0",
        "sharp": "^0.34.5",
        "socks-proxy-agent": "^8.0.5"
    }
}